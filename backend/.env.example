# ============================================================
# .env.example - Copier en .env et remplir les vraies valeurs
# ============================================================

# ── Base de données PostgreSQL ──
DB_NAME=riaddb
DB_USERNAME=riad
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT (minimum 64 caractères aléatoires) ──
# Générer avec: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# ── Email (SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-app-password-gmail
MAIL_FROM=mouadelkbabty@gmail.com
MAIL_FROM_NAME=Le Riad

# ── URLs ──
FRONTEND_URL=https://www.riad.ma
BASE_URL=https://api.riad.ma

# ── Spring ──
SPRING_PROFILES_ACTIVE=prod
